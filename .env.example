# Copy this file to `.env` and fill in your values.

AICEBERG_API_URL=https://api.test1.aiceberg.ai/eap/v1/event
AICEBERG_API_KEY=
USE_CASE_ID=
AICEBERG_USER_ID=claudeagent
AICEBERG_TIMEOUT_SECONDS=30
AICEBERG_MIN_EVENT_GAP_SECONDS=25
AICEBERG_DRY_RUN=true

# Keep true for the first prototype so Aiceberg outages do not break Claude runs.
AICEBERG_FAIL_OPEN=true

# Optional custom block message shown to the user.
AICEBERG_BLOCK_MESSAGE=This request was blocked by Aiceberg safety policy.

# Optional local-only test helper.
# If set, any prompt containing this substring will be blocked before the API call.
AICEBERG_TEST_BLOCK_SUBSTRING=
